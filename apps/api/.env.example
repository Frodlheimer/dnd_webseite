# API server
PORT=3000
HOST=0.0.0.0

# Public websocket URL returned by POST /rooms and /rooms/join
WS_URL=ws://localhost:3000/ws

# Must match docker-compose postgres service (user/password/db/port)
DATABASE_URL=postgresql://dnd:dnd@localhost:5432/dnd_vtt?schema=public

# Fail-fast guardrail for LOCAL mode (1=true, 0=false). Recommended: keep enabled.
LOCAL_STRICT=1
