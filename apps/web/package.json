{
  "name": "@dnd-vtt/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "spells:build": "tsx scripts/build-spells-pack.ts",
    "classes:build": "tsx scripts/build-classes-pack.ts",
    "lineages:build": "tsx scripts/build-lineages-pack.ts",
    "races:build": "tsx scripts/build-races-pack.ts",
    "backgrounds:build": "tsx scripts/build-backgrounds-pack.ts",
    "srd:build": "tsx scripts/build-srd-pack.ts",
    "sheets:build": "tsx scripts/build-character-sheets.ts",
    "dice3d:assets": "tsx scripts/copy-dice-box-assets.ts",
    "pdfjs:assets": "tsx scripts/copy-pdfjs-standard-fonts.ts",
    "content:build": "pnpm run spells:build && pnpm run classes:build && pnpm run lineages:build && pnpm run races:build && pnpm run backgrounds:build && pnpm run feats:build && pnpm run srd:build && pnpm run sheets:build",
    "predev": "pnpm run content:build && pnpm run dice3d:assets && pnpm run pdfjs:assets",
    "prebuild": "pnpm run content:build && pnpm run dice3d:assets && pnpm run pdfjs:assets",
    "pretest": "pnpm run content:build && pnpm run dice3d:assets && pnpm run pdfjs:assets",
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "feats:build": "tsx scripts/build-feats-pack.ts"
  },
  "dependencies": {
    "@dnd-vtt/shared": "workspace:*",
    "@3d-dice/dice-box": "^1.1.4",
    "idb": "^8.0.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "pixi.js": "^8.9.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.9"
  }
}
