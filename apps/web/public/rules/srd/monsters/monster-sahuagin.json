      "type": "p",
      "text": "Actions"
    },
    {
      "type": "p",
      "text": "Multiattack. The sahuagin makes two melee attacks: one with its bite and one with its claws or spear."
    },
    {
      "type": "p",
      "text": "Bite. Melee Weapon Attack: +3 to hit, reach 5 ft., one target. Hit: 3 (1d4 + 1) piercing damage."
    },
