        "children": [
          {
            "type": "element",
            "tag": "li",
            "children": [
              {
                "type": "element",
                "tag": "strong",
                "children": [
                  {
                    "type": "text",
                    "text": "Githzerai Psionics."
                  }
                ]
              },
              {
                "type": "text",
                "text": " You know the "
              },
              {
                "type": "text",
                "text": "Mage Hand"
              },
              {
                "type": "text",
                "text": " cantrip, and the hand is invisible when you cast the cantrip with this trait. "
              },
              {
                "type": "element",
                "tag": "ul",
                "children": [
                  {
                    "type": "element",
                    "tag": "li",
                    "children": [
                      {
                        "type": "text",
                        "text": "Starting at 3rd level, you can cast the "
                      },
                      {
                        "type": "text",
                        "text": "Shield"
                      },
                      {
                        "type": "text",
                        "text": " spell with this trait. Starting at 5th level, you can also cast the "
                      },
                      {
                        "type": "text",
                        "text": "Detect Thoughts"
                      },
                      {
                        "type": "text",
                        "text": " spell with it. Once you cast Shield or Detect Thoughts with this trait, you can’t cast that spell with it again until you finish a long rest. You can also cast either of those spells using any spell slots you have of the appropriate level."
                      }
                    ]
                  },
                  {
                    "type": "element",
                    "tag": "li",
                    "children": [
                      {
                        "type": "text",
                        "text": "Intelligence, Wisdom, or Charisma is your spellcasting ability for these spells when you cast them with this trait (choose when you select this race). None of these spells require spell components when you cast them with this trait."
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "element",
        "tag": "ul",
        "children": [
          {
            "type": "element",
            "tag": "li",
            "children": [
              {
                "type": "element",
