                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "Repair (3/Day)."
                  },
                  {
                    "type": "text",
                    "text": " The magical mechanisms inside the defender restore 2d8 + PB hit points to itself or to one construct or object within 5 feet of it."
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "th",
                "children": [
                  {
                    "type": "text",
                    "text": "Reactions"
                  }
                ]
              }
            ]
          },
