        "children": [
          {
            "type": "text",
            "text": "When you choose this domain at 1st level, you gain proficiency in the Arcana skill, and you gain two cantrips of your choice from the "
          },
          {
            "type": "text",
            "text": "wizard spell list"
          },
          {
            "type": "text",
            "text": ". For you, these cantrips count as cleric cantrips."
          }
        ]
      },
      {
        "type": "element",
