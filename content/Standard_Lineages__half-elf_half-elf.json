              {
                "type": "text",
                "text": "Detect Magic"
              },
              {
                "type": "text",
                "text": " and the "
              },
              {
                "type": "text",
                "text": "Detect Poison and Disease"
              },
              {
                "type": "text",
                "text": " spells with this trait. Starting at 3rd level, you can also cast the "
              },
              {
                "type": "text",
                "text": "See Invisibility"
              },
              {
                "type": "text",
                "text": " spell with it. Once you cast either spell with this trait, you can't cast that spell again until you finish a Long Rest. Intelligence is your Spellcasting Ability for these spells, and you don't require material components for them."
              }
            ]
          }
