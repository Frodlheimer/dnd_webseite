                    "children": [
                      {
                        "type": "text",
                        "text": "Secretive."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I trade in secrets, and am not about to let any of mine slip. (Any)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
