              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "My sibling was killed by a Tear of Virulence, and now I feed them false information whenever possible."
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "6"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "My family was wrongly imprisoned, and I act as an informant in order to secure their release."
                  }
                ]
              }
            ]
          }
        ]
