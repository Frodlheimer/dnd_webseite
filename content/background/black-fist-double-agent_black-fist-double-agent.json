                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Selfless."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I use my position to help the downtrodden avoid persecution from the authorities. (Good)"
