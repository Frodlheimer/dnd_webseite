              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "I think too highly of myself, and have an exaggerated sense of self-importance."
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "2"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "I have difficulty trusting strangers. I see spies and informants everywhere."
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "3"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "Years of getting away with minor crimes has left me believing that I am above the law, and have diplomatic immunity above my station."
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
