                    "children": [
                      {
                        "type": "text",
                        "text": "Tradition."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " The stories, legends, and songs of the past must never be forgotten, for they teach us who we are. (Lawful)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
