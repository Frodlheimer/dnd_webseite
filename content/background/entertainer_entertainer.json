                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Greed."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I'm only in it for the money and fame. (Evil)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
