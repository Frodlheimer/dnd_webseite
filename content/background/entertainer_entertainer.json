                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "People."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I like seeing the smiles on people's faces when I perform. That's all that matters. (Neutral)"
