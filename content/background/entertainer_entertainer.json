                    "children": [
                      {
                        "type": "text",
                        "text": "Honesty."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Art should reflect the soul; it should come from within and reveal who we really are. (Any)"
                  }
                ]
              }
            ]
          }
        ]
      },
