            "children": []
          },
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Equipment:"
              }
            ]
          },
          {
            "type": "text",
            "text": " A portal key (such as a bag of golden tea leaves or the tooth of a planar beast), a manifesto of your guiding philosophy, a set of "
          },
          {
            "type": "text",
            "text": "common clothes"
          },
          {
            "type": "text",
            "text": "Value: 5sp Weight: 3lbs"
          },
          {
            "type": "text",
            "text": " in your faction's style, and a "
          },
          {
            "type": "text",
            "text": "pouch"
          },
          {
            "type": "text",
            "text": "Value: 5sp Weight: 1lb"
          },
          {
            "type": "text",
            "text": " containing 10 gp worth of coins from different worlds and planes."
          }
        ]
