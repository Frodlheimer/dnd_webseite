            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Skill Proficiencies:"
              }
            ]
          },
          {
            "type": "text",
            "text": " Arcana, the skill associated with your faction (see the Sigil Faction Affinities table) or one skill of your choice."
          },
          {
            "type": "element",
            "tag": "br",
            "children": []
          },
