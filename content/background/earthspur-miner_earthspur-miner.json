              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "I can party with everyone. Whether with dwarves, or goliaths, or deep gnomes, I can find a way to have a good time."
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
