                    "children": [
                      {
                        "type": "text",
                        "text": "Cart and Sword."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " You drove a cart filled with stolen art through the middle of a battlefield while singing sea shanties to confuse the combatants."
