                    "children": [
                      {
                        "type": "text",
                        "text": "River of Shadows."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Your riverboat accidentally slipped through the veil into the Shadowfell for several hours. While you were there, you sold some stolen dragonborn artifacts before returning to this plane and paddling home."
                  }
                ]
              }
