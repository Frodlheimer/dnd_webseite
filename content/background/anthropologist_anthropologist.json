                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Power."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Common people crave strong leadership, and I do my utmost to provide it. (Lawful)"
