                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "I have a lasting grudge against one of my crop-mates, and each of us wants to see the other fail."
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
