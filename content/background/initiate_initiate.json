                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Ambition."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I’m going to prove that I deserve only the best — of everything. (Evil)"
