                    "children": [
                      {
                        "type": "text",
                        "text": "Redemption."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I will train all the harder to make up for the doubt I entertained when I was younger. (Any)"
                  }
                ]
              }
