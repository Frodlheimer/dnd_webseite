                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Strength."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " All that matters to me is my own perfection. Let everyone else seek that perfection in their own way. (Any)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
