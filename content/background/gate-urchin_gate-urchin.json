                  }
                ]
              },
              {
                "type": "element",
                "tag": "th",
                "children": [
                  {
                    "type": "text",
                    "text": "Ideal"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "1"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Loyal."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I never rat out any of my friends, even when the Red Plumes or the Rogues' Guild ask. (Lawful)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "2"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Adventurous."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I don't like doing the same thing every day. I crave variety. (Chaotic)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "3"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Strong."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Only the strong survive. I respect those who are strong and powerful. (Any)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "4"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Witty."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Brains are better than brawn. I rely on my wits and respect others who do the same. (Any)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "5"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Honest."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Others can do what they want, but I won't lie or steal, even to feed my family. (Good)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "6"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Ungrateful."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Those who give only do it to make themselves feel better. I steal from them. (Evil)"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "element",
        "tag": "h3",
        "children": [
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Gate Urchin Bonds"
              }
            ]
          }
        ]
      },
      {
        "type": "element",
        "tag": "table",
        "children": [
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "th",
                "children": [
                  {
                    "type": "text",
