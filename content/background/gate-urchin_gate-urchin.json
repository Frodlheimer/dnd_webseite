            "children": [
              {
                "type": "text",
                "text": "Gate Urchin Ideals"
              }
            ]
          }
        ]
      },
      {
        "type": "element",
        "tag": "table",
        "children": [
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
