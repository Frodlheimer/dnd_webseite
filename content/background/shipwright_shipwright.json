              {
                "type": "text",
                "text": "Skill Proficiencies:"
              }
            ]
          },
          {
            "type": "text",
            "text": " History, Perception"
          },
          {
            "type": "element",
            "tag": "br",
            "children": []
          },
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Tool Proficiencies:"
              }
            ]
          },
          {
            "type": "text",
            "text": " Carpenter's tools, Vehicles (water)"
          },
          {
            "type": "element",
            "tag": "br",
            "children": []
          },
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Equipment:"
              }
            ]
          },
          {
            "type": "text",
            "text": " A set of well-loved carpenter's tools, a blank book, 1 ounce of ink, an ink pen, a set of traveler's clothes, and a leather pouch with 10 gp"
          }
        ]
      },
      {
        "type": "element",
        "tag": "h2",
        "children": [
          {
            "type": "text",
            "text": "Feature: I'll patch it!"
          }
        ]
      },
      {
        "type": "element",
        "tag": "p",
        "children": [
          {
            "type": "text",
            "text": "Provided you have carpenter's tools and wood, you can perform repairs on a water vehicle. When you use this ability, you restore a number of hit points to the hull of a water vehicle equal to 5 × your proficiency modifier. A vehicle cannot be patched by you in this way again until after it has been pulled ashore and fully repaired."
          }
        ]
      },
