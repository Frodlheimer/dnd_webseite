                    "children": [
                      {
                        "type": "text",
                        "text": "Power."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " The only way to get ahead in this world is to attain power and hold onto it with all your might. (Evil)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
