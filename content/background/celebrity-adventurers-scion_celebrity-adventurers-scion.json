              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Wisdom."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Material wealth is an illusion. Wisdom is the real treasure. (Good)"
                  }
                ]
              }
            ]
          }
        ]
      },
