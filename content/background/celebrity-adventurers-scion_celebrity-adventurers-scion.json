                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Anonymity."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I want to be successful. And alone. With lots of guards and wards between me and everyone else in the world. (Any)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
