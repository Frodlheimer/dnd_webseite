                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Peace."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Those who can find or make peace in the chaotic world around them have everything. (Lawful)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "3"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Fame."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I've seen what fame can bring. And I'll do anything to get all that for myself. (Neutral)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "4"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Training."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Hard work, sacrifice, and training lead to success - and eventually to perfection. (Any)"
                  }
                ]
              }
            ]
          },
          {
