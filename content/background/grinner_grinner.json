                    "type": "element",
                    "tag": "em",
                    "children": [
                      {
                        "type": "text",
                        "text": "Dirge for the Emerald Fire."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " This elven song supposedly has thousands of obscure verses. Use the first two verses to spread news of death or defeat."
                  }
                ]
              }
