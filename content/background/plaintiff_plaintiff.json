            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "1"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Justice."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Those who break the law need to answer for their crimes. (Lawful)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "2"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Freedom."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " People must have the freedom to do what they want and pursue their dreams. (Chaotic)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "3"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Greed."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Everyone I see is getting theirs, so I'm surely going to get mine. (Evil)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "4"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Chaos."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " You're out of order! And you're out of order! This whole realm is out of order! (Chaotic)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "5"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Humility."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " I'm just a small part of a larger whole. So is everyone else. (Neutral)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "6"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "element",
                    "tag": "strong",
                    "children": [
                      {
                        "type": "text",
                        "text": "Responsibility."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " We all have our roles to play. I'll hold up my end of the bargain. (Any)"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "element",
        "tag": "h3",
        "children": [
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Plaintiff Bonds"
              }
            ]
          }
        ]
      },
      {
        "type": "element",
        "tag": "table",
        "children": [
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "th",
                "children": [
                  {
                    "type": "text",
