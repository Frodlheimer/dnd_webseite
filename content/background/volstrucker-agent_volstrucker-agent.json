                    "children": [
                      {
                        "type": "text",
                        "text": "Capture."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " You were captured and tortured by agents of the Kryn Dynasty and barely escaped."
                  }
                ]
              }
            ]
          },
