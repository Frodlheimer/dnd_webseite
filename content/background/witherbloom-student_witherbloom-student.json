                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "Everything in this world dies eventually. The question is, what will you do with the time you have left?"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
