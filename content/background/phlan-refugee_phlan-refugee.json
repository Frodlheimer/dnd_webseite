                    "children": [
                      {
                        "type": "text",
                        "text": "Justice."
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Corruption brought Phlan down. I will not tolerate that any longer. (Lawful)"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
