              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "A criminal syndicate I once played for isn't happy I left the game, and its enforcers are looking for me."
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tag": "tr",
            "children": [
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "6"
                  }
                ]
              },
              {
                "type": "element",
                "tag": "td",
                "children": [
                  {
                    "type": "text",
                    "text": "Urchins once helped me find marks for my games. Now I'm driven to help them escape the streets."
                  }
                ]
              }
            ]
          }
        ]
