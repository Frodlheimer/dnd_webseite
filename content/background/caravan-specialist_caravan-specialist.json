    "tree": [
      {
        "type": "element",
        "tag": "p",
        "children": [
          {
            "type": "text",
            "text": "Source: Mulmaster Bonds and Backgrounds"
          }
        ]
      },
      {
        "type": "element",
        "tag": "p",
        "children": [
          {
            "type": "text",
            "text": "You are used to life on the road. You pride yourself at having traveled every major tradeway in the Moonsea region, including the best back roads and shortcuts. When traveling these roads, you know where the best inns, campsites, and water sources are located, as well as potential locations of danger such as ambush. Having worked the roads as long as you have, you have made many acquaintances and find it easy to pick up information and rumors floating from town to town. You are skilled with beasts of burden and handling and repairing wagons of all kinds."
          }
        ]
      },
      {
        "type": "element",
        "tag": "p",
        "children": [
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Skill Proficiencies:"
              }
            ]
          },
          {
            "type": "text",
            "text": " Animal Handling, Survival"
          },
          {
            "type": "element",
            "tag": "br",
            "children": []
          },
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Tool Proficiencies:"
              }
            ]
          },
          {
            "type": "text",
            "text": " Land Vehicles"
          },
          {
            "type": "element",
            "tag": "br",
            "children": []
          },
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Languages:"
              }
            ]
          },
          {
            "type": "text",
            "text": " One of your choice"
          },
          {
            "type": "element",
            "tag": "br",
            "children": []
          },
          {
            "type": "element",
            "tag": "strong",
            "children": [
              {
                "type": "text",
                "text": "Equipment:"
              }
